{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A blog post entity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "coverImage": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "readingTime": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "author": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "avatar": { "type": "string" },
            "role": { "type": "string" }
          }
        },
        "featured": { "type": "boolean" },
        "trending": { "type": "boolean" }
      },
      "required": ["slug", "title", "content", "date", "category", "author"]
    },
    "User": {
      "title": "User",
      "description": "User profile for access control",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a blog post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorName", "content", "createdAt"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of blog posts"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Subcollection of comments on a specific post"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
