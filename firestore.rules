rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: posts
    // Document ID: auto-generated or slug
    // Fields:
    //   - title: string (required, < 200 chars)
    //   - slug: string (required, unique)
    //   - excerpt: string (optional, < 500 chars)
    //   - content: string (required, < 100000 chars)
    //   - coverImage: string (optional, url)
    //   - date: string (required, ISO 8601)
    //   - readingTime: string (optional)
    //   - category: string (required)
    //   - author: map (required)
    //       - name: string
    //       - avatar: string
    //       - role: string
    //   - featured: bool (optional)
    //   - trending: bool (optional)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string
    //   - email: string
    //   - role: string ('admin')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "abhinavj@leewayhertz.com" && request.auth.token.email_verified == true));
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidDate(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}.*");
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /posts/{postId} {
      // Publicly readable so visitors can see the blog
      allow read: if true;
      
      // Only admins can modify blog posts
      allow write: if isAdmin();
    }
    
    // Default deny for everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
